# This is a TEMPLATE. Do NOT put real secrets here — this file is committed to git.
# Copy it to `.env` (which is gitignored) and fill in real values there, OR set them
# in the Claude Code web environment-variables config so routine sessions inherit them.
#
# ── Core AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ORCHESTRATOR_MODEL=claude-sonnet-4-6   # master synthesis model
AGENT_MODEL=claude-sonnet-4-6          # per-agent analysis model
LOG_LEVEL=INFO

# ── Robinhood (agentic account) ──────────────────────────────────────────────
# Execution happens through the Robinhood agentic MCP tools in the agent runtime.
# This MUST be an agentic-enabled account (agentic_allowed=true). Find it via the
# get_accounts MCP tool. Leave blank to run in proposals-only mode.
ROBINHOOD_ACCOUNT_NUMBER=

# Master switch. false = generate proposals only (never place live orders).
# true  = the agent runtime may auto-execute orders that pass ALL risk gates.
AUTO_EXECUTE=false

# ── Hard risk gates (enforced in code by stock_oracle/risk.py) ────────────────
MAX_ORDER_USD=100              # max notional per single order
MAX_POSITION_PCT=0.25         # max fraction of account value in one position
MAX_OPEN_POSITIONS=5          # max concurrent open positions
MAX_TRADES_PER_DAY=5          # max new BUYs per day (overtrading guard; one per routine slot)
DAILY_LOSS_LIMIT_USD=25       # halt new BUYs once today's realised loss hits this
MIN_CONFIDENCE=0.58           # minimum oracle confidence to act
STOP_LOSS_PCT=0.06            # protective stop applied to every entry (6%)
TAKE_PROFIT_PCT=0.12          # profit target applied to every entry (12%)
MIN_CASH_BUFFER_USD=1         # always keep this much cash unspent
MIN_PRICE_USD=3               # reject names cheaper than this (illiquidity guard)
EARNINGS_BLACKOUT_DAYS=3      # no NEW entries within N days of earnings (gap guard; 0=off)

# ── Universe ─────────────────────────────────────────────────────────────────
# Comma-separated tickers for the protected CORE list. Blank uses the default
# liquid large-cap set. Core names are always analysed and never pruned.
WATCHLIST=

# ── Discovery (autonomous prospecting) ───────────────────────────────────────
# These are the MOST PERMISSIVE settings — give the agent room to find opportunities.
# The self-governor (stock_oracle/performance.py) only ever clamps TIGHTER than these
# when discovery-sourced trades lose money, then relaxes back toward them when they win.
DISCOVERY_ENABLED=true        # scan free screeners for fresh prospects each run
MAX_WATCHLIST=20             # cap on total universe (core + discovered)
DISCOVERY_MAX_NEW=6          # max brand-new names promoted per run
DISCOVERY_MIN_PRICE=5        # baseline floor price (anti penny-pump)
DISCOVERY_MIN_VOLUME=1000000 # baseline floor session volume (liquidity)

# ── Performance / concurrency ────────────────────────────────────────────────
# Speed vs rate-limit headroom. AGENT_CONCURRENCY caps total simultaneous Claude
# calls across all agents; SYMBOL_CONCURRENCY = how many symbols analyse at once.
# Raise to shorten large-watchlist runs; lower if you hit API rate limits.
AGENT_CONCURRENCY=6
SYMBOL_CONCURRENCY=3

# ── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=stock_oracle.db
